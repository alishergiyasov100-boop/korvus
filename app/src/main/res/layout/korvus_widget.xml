<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <LinearLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_card_bg"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/widget_line_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_msg_bg"
                android:padding="10dp"
                android:textColor="@color/korvus_ink"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="@string/widget_hint"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/widget_line_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_msg_bg"
                android:padding="10dp"
                android:textColor="@color/korvus_ink_soft"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text=""
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/widget_line_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_msg_bg"
                android:padding="10dp"
                android:textColor="@color/korvus_ink_soft"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@drawable/widget_wave_bg"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@mipmap/ic_launcher_foreground"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/widget_title"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
